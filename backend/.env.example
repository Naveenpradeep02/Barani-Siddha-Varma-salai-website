PORT=5000
NODE_ENV=development
FRONTEND_URL=https://bnaranisiddha.netlify.app
BACKEND_URL=https://barani-siddha-varma-salai-website.onrender.com
CORS_ORIGIN=https://bnaranisiddha.netlify.app,http://localhost:3000,http://127.0.0.1:3000

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ecom_db

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=dgrow-ecom

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=Admin
ADMIN_ROLE=admin
ADMIN_RESET_PASSWORD=false

# Cashfree Payments
CASHFREE_ENV=production
CASHFREE_CLIENT_ID=replace-with-cashfree-client-id
CASHFREE_CLIENT_SECRET=replace-with-cashfree-client-secret
CASHFREE_ENDPOINT=https://api.cashfree.com/pg
CASHFREE_API_VERSION=2025-01-01

SHIPROCKET_API_URL=https://apiv2.shiprocket.in/v1/external
SHIPROCKET_API_EMAIL=replace-with-shiprocket-email
SHIPROCKET_API_PASSWORD=replace-with-shiprocket-password

